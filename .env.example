# ============================================
# DealGuider – Environment Variables
# ============================================
# All VITE_ prefixed variables are client-side (bundled by Vite).
# Server-side variables are set in Supabase Edge Function secrets.

# ---- CLIENT-SIDE (required for frontend) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- MOOLRE SANDBOX (reused existing integration) ----
# Moolre public key is used by both client (constants.js) and
# server-side edge functions (moolre-init-payment, moolre-webhook).
VITE_MOOLRE_PUBLIC_KEY=your-moolre-public-key

# ---- MERCHANT WEBHOOK (optional, for signed webhook delivery) ----
# Merchant webhook secret is auto-generated per merchant and stored in DB.
# The system uses HMAC-SHA256 signatures (X-DealGuider-Signature header)
# for all outgoing merchant webhooks.

# ---- SERVER-SIDE (set in Supabase Edge Function secrets) ----
# These are NOT VITE_ prefixed — they are injected by Supabase
# when deploying edge functions. Do NOT commit these values.
#
# SUPABASE_URL                           # Same as VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY              # Service role key (bypasses RLS)
# MOOLRE_API_USER                        # Moolre sandbox API user
# MOOLRE_PUBLIC_KEY                      # Moolre sandbox public key
# MOOLRE_PRIVATE_KEY                     # Moolre sandbox private key (for payouts)
# MOOLRE_ACCOUNT_NUMBER                  # Moolre sandbox account number
# MOOLRE_BASE_URL=https://api.moolre.com # Moolre base URL (sandbox environment)
